// Barrelman custom foot model.
// Renamed from GraphHopper's built-in foot.json because custom_model_files
// refuses names that conflict with built-in profile names. Behavior is
// otherwise identical to the upstream foot profile.

{
  "priority": [
    { "if": "!foot_access || hike_rating >= 2", "multiply_by": "0" },
    { "else": "", "multiply_by": "foot_priority"},
    { "if": "country == DEU && road_class == BRIDLEWAY && foot_road_access != YES", "multiply_by": "0" },
    { "if": "mtb_rating > 3", "multiply_by": "0.7" },
    { "if": "foot_road_access == PRIVATE", "multiply_by": "0.1" }
  ],
  "speed": [
    { "if": "true", "limit_to": "foot_average_speed" }
  ]
}
