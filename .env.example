# Dev workflow: default `docker compose` to the base + dev override so the
# barrelman API runs with hot-reload (bun --hot, source mounted) — code changes
# in src/ apply instantly, no image rebuild. Comment out for a prod-style run.
COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Database
DATABASE_URL=postgresql://barrelman:barrelman@localhost:5434/barrelman
BARRELMAN_DB_PASSWORD=barrelman

# Server
# In Docker (docker-compose.yml), PORT is hardcoded to 5001.
# In local dev without Docker, use the same port or any available port.
PORT=5001

# Auth (simple shared secret — change before any public/production deployment)
BARRELMAN_API_KEY=brm_dev_changeme

# Ollama (for semantic embeddings — optional)
OLLAMA_HOST=http://localhost:11434

# ── Region selection (unified) ────────────────────────────────────────────────
# Single source of truth for which regions the whole pipeline imports — OSM,
# GTFS, GBFS, and the Pelias geocoder all resolve from config/regions.json.
# Comma-separated region keys for dev, or "global" for prod.
#   dev (default): north-carolina,nyc-metro
#   prod:          global
REGIONS=north-carolina,nyc-metro

# ── OSM Import & Daily Updates ────────────────────────────────────────────────
# Legacy single-extract override. When set, it bypasses REGIONS for run-import.sh
# (and update-osm.sh full mode). Normally leave unset and use REGIONS above.
# Find your region at https://download.geofabrik.de
# GEOFABRIK_URL=https://download.geofabrik.de/north-america/us/north-carolina-latest.osm.pbf

# Replication server URL. Used by update-osm.sh (replication mode) and init-replication.sh.
# Typically the extract URL with "-updates/" appended.
GEOFABRIK_REPLICATION_URL=https://download.geofabrik.de/north-america/us/north-carolina-updates/

# Update mode for update-osm.sh: "replication" (incremental diffs) or "full" (re-download + re-import)
# "replication" is faster; "full" is simpler and always consistent.
# Requires init-replication.sh to be run once before using "replication" mode.
UPDATE_MODE=replication

# ── GTFS Transit Data ─────────────────────────────────────────────────────────
# GTFS feeds are resolved from REGIONS above (config/regions.json gtfsRegion per
# region). Set GTFS_REGION only to override with a single region token, e.g.
# "global" = all ~2,800 feeds.
# GTFS_REGION=nc

# Transitland API key (get one at https://www.transit.land/users/sign_up)
TRANSITLAND_API_KEY=

# MOTIS transit router URL.
# In docker-compose this is set automatically via service networking.
MOTIS_URL=http://localhost:8080

# How often (seconds) MOTIS re-polls every feed's GTFS-RT URLs. Baked into the
# generated motis/config.yml (timetable.update_interval) by the GTFS import /
# `bun run import/generate-motis-config.ts`. MOTIS default is 60s, which means
# continuously fetching realtime for every agency. On a dev box that only
# occasionally exercises transit, raise this (e.g. 600) to cut the polling while
# keeping realtime data present and testable. Leave unset for prod.
# MOTIS_RT_UPDATE_INTERVAL=600

# ── GraphHopper Routing Engine ────────────────────────────────────────────────
# Upstream URL for the GraphHopper container. Used by the /graphhopper proxy in
# the barrelman API. In docker-compose this is set automatically; override here
# for local dev (e.g. when running `bun run dev` against a containerised GH).
GRAPHHOPPER_URL=http://localhost:8989

# JVM options for GraphHopper (memory, GC, etc.)
GRAPHHOPPER_JAVA_OPTS="-Xmx2g -Xms1g"
