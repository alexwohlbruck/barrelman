# Copy to .env and adjust for your machine.
COMPOSE_PROJECT_NAME=pelias
# Absolute path to the Pelias data dir (Elasticsearch index, downloads, etc.).
# Keep it inside this folder so everything stays under barrelman/pelias.
DATA_DIR=/absolute/path/to/barrelman/pelias/data
# Container user. Empty = each image's default (Elasticsearch runs as its own user).
DOCKER_USER=
