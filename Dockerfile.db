FROM pgvector/pgvector:pg16

# Install PostGIS + osm2pgsql on top of pgvector base image
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      postgresql-16-postgis-3 \
      postgresql-16-postgis-3-scripts \
      osm2pgsql \
      wget && \
    rm -rf /var/lib/apt/lists/*
