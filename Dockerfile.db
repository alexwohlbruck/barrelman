FROM pgvector/pgvector:pg16

# pgvector/pgvector:pg16 doesn't include PostGIS, and postgis/postgis doesn't
# include pgvector — so we need a custom image that has both, plus osm2pgsql
# for running imports and daily diffs, and Python for osm2pgsql-replication.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      postgresql-16-postgis-3 \
      postgresql-16-postgis-3-scripts \
      osm2pgsql \
      wget \
      python3 \
      python3-psycopg2 \
      python3-requests && \
    rm -rf /var/lib/apt/lists/*

# Bake in DB init script and OSM import assets so no repo clone is needed.
COPY scripts/init-extensions.sh /docker-entrypoint-initdb.d/init-extensions.sh
COPY import/ /app/import/
COPY scripts/ /app/scripts/

ENV BARRELMAN_DATA_DIR=/data
