  <node id="1031" lat="41.88036" lon="-87.6300"/>

  <!-- B: way 403 then a hole then way 404 -->
  <node id="1041" lat="41.8830" lon="-87.6400"/>
  <node id="1042" lat="41.8830" lon="-87.6390"/>
  <node id="1043" lat="41.8830" lon="-87.6380"/>
