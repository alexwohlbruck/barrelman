<?xml version='1.0' encoding='UTF-8'?>
<osm version="0.6" generator="shapesnap-test">
  <!-- Matching scenarios at lat ~41.88 (lon ~82.9 km/deg, lat ~111 km/deg).

       A. ways 401/402: parallel rails ~40 m apart, NO shared nodes.
          A shape hugging 401 must match 401 end-to-end.
       B. ways 403/404: collinear rails with a ~166 m hole between them
          (no topological connection). A shape across the hole must
          break + bridge with the original segment.
       C. way 405: lone rail; a shape offset ~40 m (inside the 50 m
          candidate radius, outside the 25 m coverage tolerance) must
          match but then fail the coverage gate -> fallback.
       D. way 406: one long (~8.3 km) continuous rail at lat 41.8900;
          a shape that hugs it except for a short ~70 m southward bulge
          (past the 50 m dense radius, inside the 2x gap-retry radius)
          must RETRY the gap and reconnect on 406 with no break — the
          Joralemon shape-vs-track offset in miniature. Long so the
          bulge observations stay under the 5% coverage budget; far
          from every other scenario (405 is ~410 m south of the bulge).
  -->

  <!-- A: way 401 (south track) -->
  <node id="1001" lat="41.8800" lon="-87.6400"/>
  <node id="1002" lat="41.8800" lon="-87.6390"/>
  <node id="1003" lat="41.8800" lon="-87.6380"/>
  <node id="1004" lat="41.8800" lon="-87.6370"/>
