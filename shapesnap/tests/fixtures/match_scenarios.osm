  <node id="1010" lat="41.8800" lon="-87.6310"/>
  <node id="1011" lat="41.8800" lon="-87.6300"/>
  <!-- A: way 402 (north track, ~40 m away, disjoint node ids) -->
  <node id="1021" lat="41.88036" lon="-87.6400"/>
